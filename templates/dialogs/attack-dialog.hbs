<form>
  {{console "Attack Dialog 2"}}
  {{console this}}
  <label>Skill: {{skl.label }} {{#if (not isStarshipweapon)}} {{skl.base}}/{{skl.good}}/{{skl.amazing}} {{skl.stepdie}}
    {{/if}} </label>

  <div class="form-group">
    <label>Base Roll</label>
    <input type="text" name="formula" value="{{formula}}" disabled />
  </div>
  <div class="form-group">
    <label>Difficulty Steps</label>
    <select name="dstep">
      {{selectOptions difficultySteps selected=step}}
    </select>
  </div>

      
        <div class="form-group" data-tooltip="{{ localize "d100A.Items.Weapon.movementTooltip" }}">
          <label>{{ localize "Movement" }}</label>
           <select name="movement">
           
             {{selectOptions d100A.movementType selected=movement}}


          </select>
        </div>



      
  {{#if isStarshipweapon}}
  <div class="form-group"  >
    <label>Weapons Operator</label>
    <select name="operator">
      {{console "Attack dia 43"}}
      {{console validgunner}}
      {{selectOptions operatorOptions selected=operator}}
    </select>

  </div>



  {{/if}}


  <table style="width:99%" style="font-size: 10px;" >
    <thead>
      <tr style="font-size: 13px;">
        <th>
          Target
        </th>
        <th data-tooltip="{{ localize "d100A.Items.Weapon.rangeTooltip" }}" >
          Range
        </th>
        <th data-tooltip="{{ localize "d100A.Items.Weapon.resistanceTooltip" }}">
          Res
        </th>
        <th data-tooltip="{{ localize "d100A.Items.Weapon.coverTooltip" }}">
          Cover
        </th>
        <th data-tooltip="{{ localize "d100A.Items.Weapon.dodgeTooltip" }}">
          Dodge
        </th>
      </tr>

    </thead>
    <tbody>
      {{#each targetData as |target id|}}
      <tr style="font-size: 11px; height: 16px" >
        <td>
          {{target.Name}}
        </td>
        <td>
          <div class="form-group">
            <select name="range{{id}}">
              {{selectOptions ../d100A.itemAttack.range selected=target.rangecat }}
              
            </select>
          </div>
        </td>
        <td>
          <div class="form-group" >
            <select name="resistance{{id}}">
              {{selectOptions ../d100A.resistanceType selected=target.resistance }}
              

            </select>
          </div>
        </td>
        <td>
          <div class="form-group" >
            <select name="cover{{id}}">
             
               {{selectOptions ../d100A.coverType selected=target.cover }}

            </select>
          </div>
        </td>
        <td>
          <div class="form-group" >
            <select name="dodge{{id}}">

               {{selectOptions ../d100A.dodgeType selected=target.dodge }} 
              
            </select>
          </div>
        </td>

      </tr>
      {{/each}}
    </tbody>
  </table>


  
  <ol></ol>
  {{#each defenceData.armor as |armor index|}}
  <li>{{armor.name}}</li>
  {{/each}}


  </ol>

  <div class="form-group">
    <label>RollMode</label>
    <select name="rollMode">
     
      {{selectOptions rollModes selected=rollMode localize=true }} 


    </select>
  </div>
  <div class="form-group">

  </div>

</form>