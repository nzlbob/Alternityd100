<form>
 {{console "Attack Dialog 2"}}
 {{console this}}

    <div class="form-group">
    <label>Base Roll</label>
    <input type="text" name="formula" value="{{formula}}" disabled/>
  </div>
<div class="form-group">
    <label>Difficulty Steps</label>
    <select name="dstep">
  {{selectOptions difficultySteps selected=step}}
    </select>
 </div>

 {{#if isStarshipweapon}}
 <div class="form-group">
<label>Weapons Operator</label>
    <select name="operator">
     {{console "Attack dia 43"}}
     {{console validgunner}}
      {{selectOptions operatorOptions selected=operator}}
    </select>

  </div>



  {{/if}}


<table style="width:99%">
  <tr>
    <td colspan="4">
      <label>Skill: {{skl.label }}  {{#if (not isStarshipweapon)}} {{skl.base}}/{{skl.good}}/{{skl.amazing}} {{skl.stepdie}} {{/if}}  </label>
    </td>
  </tr>

<!--- Row 1 -->
  <tr style="height: 18px; " >
    <td>
      <label>{{ localize "Range" }}</label>
    </td>

    <td>  
      <div class="form-group" data-tooltip="{{ localize "d100A.Items.Weapon.dmgtypeTooltip" }}">
        <select name="range">
          {{selectOptions d100A.itemAttack.range selected=range}}
        </select>
      </div> 
    </td>

    <td>
      <label>{{ localize "Res Mod" }}</label>
    </td>

    <td>
    <div class="form-group" data-tooltip="{{ localize "d100A.Items.Weapon.ResistanceTooltip" }}">
      <select name="resistance">
        {{selectOptions d100A.resistanceType selected=resistance}}
      </select>
    </div>  
  </tr>

<!--- Row 2 -->

<tr style="height: 18px; " >
  <td>
    <label>{{ localize "Movement" }}</label>
  </td>
    
  <td>
    <div class="form-group" data-tooltip="{{ localize "d100A.Items.Weapon.movementTooltip" }}">
      <select name="movement">
        {{selectOptions d100A.movementType selected=movement}}
        </select>
    </div>  



  </td>
  
 <td>
  <label>{{ localize "Cover" }}</label>
  </td>
    
  <td>
    <div class="form-group" data-tooltip="{{ localize "d100A.Items.Weapon.coverTooltip" }}">
      <select name="cover">
        {{selectOptions d100A.coverType selected=cover}}
      </select>
    </div>  
  </td>
</tr>

<!--- Row 3A -->

<tr style="height: 18px; " >
  <td>
    <label>{{ localize "-" }}</label>
  </td>
    
  <td>
    <div class="form-group" data-tooltip="{{ localize "d100A.Items.Weapon.blankTooltip" }}">
      <select name="blanks">
        {{selectOptions d100A.coverType selected=blanks}}
        </select>
    </div>  
  </td>

  <!--- Row 3B -->
  <td>
    <label>{{ localize " Dodge" }}</label>
  </td>
  
  <td>
    <div class="form-group" data-tooltip="{{ localize "d100A.Items.Weapon.dodgeTooltip" }}">
      <select name="dodge">
        {{selectOptions d100A.dodgeType selected=dodge}}
      </select>
    </div>  
  </td>
</tr>
</table>
 <ol></ol>
  {{#each defenceData.armor as |armor index|}}
    <li>{{armor.name}}</li>
    {{/each}}


</ol>

  <div class="form-group">
    <label>RollMode</label>
    <select name="rollMode">
      {{selectOptions rollModes selected=rollMode localize=true}}
    </select>
  </div>
   <div class="form-group">

    </div>
    
</form>
