<section class="d100a-attack-dialog">
  <header class="d100a-attack-dialog__header">
    <div class="d100a-attack-dialog__skill">
      Skill: {{skl.label}}
      {{#if (not isStarshipweapon)}}
        <span class="d100a-attack-dialog__oga">{{skl.base}}/{{skl.good}}/{{skl.amazing}} {{skl.stepdie}}</span>
      {{/if}}
    </div>
  </header>

  <div class="form-group">
    <label>Base Roll</label>
    <input type="text" name="formula" value="{{formula}}" disabled />
  </div>

  <div class="form-group">
    <label>Difficulty Steps</label>
    <select name="dstep">
      {{selectOptions difficultySteps selected=dstep}}
    </select>
  </div>

  <div class="form-group" data-tooltip='{{ localize "d100A.Items.Weapon.movementTooltip" }}'>
    <label>{{ localize "Movement" }}</label>
    <select name="movement">
      {{selectOptions d100A.movementType selected=movement}}
    </select>
  </div>

  {{#if isStarshipweapon}}
  <div class="form-group">
    <label>Weapons Operator</label>
    <select name="operator">
      {{selectOptions operatorOptions selected=operator}}
    </select>
  </div>
  {{/if}}

  <table class="d100a-attack-dialog__targets">
    <thead>
      <tr>
        <th>Target</th>
        <th data-tooltip='{{ localize "d100A.Items.Weapon.rangeTooltip" }}'>Range</th>
        <th data-tooltip='{{ localize "d100A.Items.Weapon.resistanceTooltip" }}'>Res</th>
        <th data-tooltip='{{ localize "d100A.Items.Weapon.coverTooltip" }}'>Cover</th>
        <th data-tooltip='{{ localize "d100A.Items.Weapon.dodgeTooltip" }}'>Dodge</th>
      </tr>
    </thead>
    <tbody>
      {{#each targetData as |target id|}}
      <tr>
        <td class="d100a-attack-dialog__target-name">{{target.Name}}</td>
        <td>
          <select name="range{{id}}">
            {{selectOptions ../d100A.itemAttack.range selected=target.rangecat}}
          </select>
        </td>
        <td>
          <select name="resistance{{id}}">
            {{selectOptions ../d100A.resistanceType selected=target.resistance}}
          </select>
        </td>
        <td>
          <select name="cover{{id}}">
            {{selectOptions ../d100A.coverType selected=target.cover}}
          </select>
        </td>
        <td>
          <select name="dodge{{id}}">
            {{selectOptions ../d100A.dodgeType selected=target.dodge}}
          </select>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <div class="form-group">
    <label>Roll Mode</label>
    <select name="rollMode">
      {{selectOptions rollModes selected=rollMode localize=true}}
    </select>
  </div>

  <footer class="d100a-attack-dialog__buttons">
    <button type="button" data-action="roll" class="d100a-attack-dialog__roll">
      <i class="fas fa-crosshairs"></i> Roll
    </button>
    <button type="button" data-action="cancel" class="d100a-attack-dialog__cancel">
      Cancel
    </button>
  </footer>
</section>
