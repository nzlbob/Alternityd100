<section class="d100a-roll-dialog">
  {{#if stepflavor}}
  <div class="d100a-roll-dialog__hint">{{stepflavor}}</div>
  {{/if}}

  <div class="form-group">
    <label>Base Roll</label>
    <input type="text" name="formula" value="{{formula}}" disabled/>
  </div>

  <div class="form-group">
    <label>Difficulty Steps</label>
    <select name="dstep">
      {{selectOptions difficultySteps selected=dstep}}
    </select>
  </div>

  <div class="form-group">
    <label>Roll Mode</label>
    <select name="rollMode">
      {{selectOptions rollModes selected=rollMode localize=true}}
    </select>
  </div>

  <footer class="d100a-roll-dialog__buttons">
    <button type="button" data-action="roll" class="d100a-roll-dialog__roll">
      <i class="fas fa-dice-d20"></i> Roll
    </button>
    <button type="button" data-action="cancel" class="d100a-roll-dialog__cancel">
      Cancel
    </button>
  </footer>
</section>
