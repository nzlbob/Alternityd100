<header class="card-header flexrow" data-actor-id="{{actor._id}}" data-item-id="{{item._id}}" {{#if tokenUuid}}data-token-uuid="{{tokenUuid}}"{{/if}}>
  <img class="item-image" src="{{item.img}}" data-tooltip="{{item.name}}" />
  <div class="item-info">
    {{#if item.name}}<div class="item-name">{{item.name}}</div>{{/if}}
    {{#if flavor}}<div class="item-flavor">{{flavor}}</div>{{/if}}
    {{#if stepflavor}}<div class="item-stepflavor">{{stepflavor}}</div>{{/if}}
  </div>
</header>

<div class="card-content">
  {{description}}
  <!-- enrich description rollData=@root.rollData}} -->
  </div>
 
 


{{#if range}}
<div class="card-range gm-sensitive" data-range="{{range}}" {{#if rangeFormula}}title="{{rangeFormula}}"{{/if}}>
  {{localize "PF1.Range"}}: {{rangeLabel}}
</div>
{{/if}}
